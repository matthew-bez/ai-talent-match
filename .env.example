# Local Postgres Configuration (used by docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=ai_cv_analyzer

# Prisma / NestJS connection string (must match the DB_* values above)
DATABASE_URL="postgresql://postgres:change_me@localhost:5432/ai_cv_analyzer?schema=public"

# NestJS API
PORT=3000

# Auth / JWT (use long random strings in production)
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin allowed by CORS (must match where the SPA runs)
FRONTEND_ORIGIN=http://localhost:5173

# Object storage (MinIO locally, S3-compatible — swap endpoint/creds for real AWS later)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio
S3_BUCKET=talent-match
S3_FORCE_PATH_STYLE=true
S3_PORT=9000
S3_CONSOLE_PORT=9001
