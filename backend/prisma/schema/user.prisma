model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  refreshToken String?  @map("refresh_token")

  // Candidate profile (LinkedIn-style)
  headline          String?  // short professional tagline
  bio               String?  // longer "About" description
  location          String?
  phone             String?
  profilePictureKey String?  @map("profile_picture_key") // S3 object key
  skills            String[] @default([])

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizationMemberships OrganizationMember[]
  resumes                 Resume[]
  applications            Application[]        @relation("ApplicantApplications")
  jobPostings             JobPosting[]         @relation("UserJobPostings")
  experiences             Experience[]
  education               Education[]
  certifications          Certification[]

  @@map("users")
}
